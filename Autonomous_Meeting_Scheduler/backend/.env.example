GOOGLE_CLIENT_SECRET_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json
GMAIL_POLL_INTERVAL_SECONDS=15
GMAIL_MAX_MESSAGES=5
GMAIL_USER_ID=me
GMAIL_MARK_AS_READ=false
GOOGLE_SCOPES=gmail.readonly,calendar.readonly

# OpenAI key for LangChain extraction chain
OPENAI_API_KEY=<your-openai-api-key>

# Scheduling preferences
# Working hours in 24h format (local time)
SCHEDULE_WORK_START_HOUR=9
SCHEDULE_WORK_END_HOUR=18
# Minimum slot duration in minutes
SCHEDULE_MIN_SLOT_MINUTES=30
# How many days ahead to search for slots
SCHEDULE_LOOKAHEAD_DAYS=7